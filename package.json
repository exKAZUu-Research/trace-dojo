{
  "name": "trace-dojo",
  "version": "0.0.0-semantically-released",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/exKAZUu-Research/trace-dojo.git"
  },
  "license": "Apache-2.0",
  "author": "Kazunori Sakamoto",
  "scripts": {
    "build": "wb buildIfNeeded -c 'yarn run build/core'",
    "build/core": "next build",
    "calculate-score": "WB_ENV=restored yarn wb prisma seed -f prisma/calculateScores.ts",
    "cleanup": "yarn gen-code && yarn format && yarn lint-fix",
    "db-help": "wb prisma --help",
    "db-migrate-apply": "wb prisma migrate",
    "db-migrate-create": "wb prisma migrate-dev",
    "db-reset": "wb prisma reset",
    "db-restore": "wb prisma restore",
    "db-view": "wb prisma studio",
    "db-view-restored": "wb prisma studio --restored",
    "deploy": "wb optimizeForDockerBuild --outside && fly deploy -c fly-${WB_ENV}.toml --build-arg ARCH=x86_64 --build-arg WB_ENV=${WB_ENV} --build-arg WB_VERSION=${WB_VERSION}",
    "format": "sort-package-json && yarn format-code",
    "format-code": "oxfmt --write --no-error-on-unmatched-pattern . '!**/package.json'",
    "gen-code": "prisma generate && chakra-cli tokens src/theme.ts",
    "lint": "oxlint --no-error-on-unmatched-pattern .",
    "lint-fix": "yarn lint --fix",
    "prepare": "lefthook install || true",
    "start": "wb start",
    "start-docker": "wb start --mode docker",
    "start-stg": "wb start --mode staging",
    "test": "wb test",
    "test-unit": "wb test --unit",
    "test/ci-setup": "wb prisma reset",
    "typecheck": "wb typecheck",
    "verify": "wb verify",
    "verify-full": "wb verify --full"
  },
  "resolutions": {
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-is": "19.2.6"
  },
  "dependencies": {
    "@chakra-ui/next-js": "2.4.2",
    "@chakra-ui/react": "2.10.9",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@prisma/client": "6.19.2",
    "@rvf/set-get": "7.0.2",
    "@tanstack/react-query": "5.100.9",
    "@trpc/client": "11.17.0",
    "@trpc/next": "11.17.0",
    "@trpc/react-query": "11.17.0",
    "@trpc/server": "11.17.0",
    "@willbooster/shared-lib": "7.4.14",
    "@willbooster/shared-lib-react": "5.3.12",
    "at-decorators": "7.1.0",
    "dayjs": "1.11.20",
    "dotenv-cli": "11.0.0",
    "fast-deep-equal": "3.1.3",
    "framer-motion": "12.38.0",
    "immer": "11.1.8",
    "jsonwebtoken": "9.0.3",
    "jwks-rsa": "4.0.1",
    "next": "16.2.6",
    "nextjs-cors": "2.2.1",
    "nextjs-toploader": "3.9.17",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "pm2": "7.0.1",
    "prisma": "6.19.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-icons": "5.6.0",
    "react-idle-timer": "5.7.3",
    "react-syntax-highlighter": "16.1.1",
    "seedrandom": "3.0.5",
    "server-only": "0.0.1",
    "superjson": "2.2.6",
    "supertokens-auth-react": "0.51.2",
    "supertokens-node": "24.0.2",
    "supertokens-web-js": "0.16.0",
    "use-context-selector": "2.0.0",
    "use-immer": "0.11.0",
    "usehooks-ts": "3.1.1",
    "uuid": "13.0.2",
    "zod": "4.4.3",
    "zod-form-data": "3.0.1"
  },
  "devDependencies": {
    "@chakra-ui/cli": "2.5.8",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.6.2",
    "@types/react-dom": "19.2.3",
    "@types/react-syntax-highlighter": "15.5.13",
    "@types/seedrandom": "3.0.8",
    "@typescript/native-preview": "7.0.0-dev.20260510.1",
    "@willbooster/oxfmt-config": "1.2.2",
    "@willbooster/oxlint-config": "1.4.6",
    "@willbooster/wb": "13.14.0",
    "babel-plugin-react-compiler": "1.0.0",
    "build-ts": "17.1.13",
    "concurrently": "9.2.1",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "lefthook": "2.1.6",
    "open-cli": "9.0.0",
    "oxfmt": "0.49.0",
    "oxlint": "1.64.0",
    "oxlint-tsgolint": "0.22.1",
    "semantic-release": "25.0.3",
    "sort-package-json": "3.6.1",
    "typescript": "5.9.3",
    "vitest": "4.1.5",
    "wait-on": "9.0.6"
  },
  "packageManager": "yarn@4.14.1",
  "publishConfig": {
    "access": "public"
  },
  "prisma": {
    "seed": "build-ts run prisma/seed.mts"
  }
}
